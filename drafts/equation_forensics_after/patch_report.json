    "5": "C_t = Σ_(k=1)^t δ_k    (5)",
    "6": "z_lo = clamp(-min_t C_t, 0, 1),    z_hi = clamp(1 - max_t C_t, 0, 1)    (6)",
    "7": "SOC_anchor = z_lo + max(z_hi - z_lo, ε) · σ(l_anchor),    ε = 10^(-6)    (7)",
    "8": "SOC_hat,t = SOC_anchor + C_t,    for all t ∈ 1, ..., T    (8)",
    "9": "limit*_t = |I_t| · η* · γ,    η* = 2,0    (9)",
    "10": "r_Δ = mean(|Δs_hat|) / mean(|Δs|) ≈ 1,0 pada η* = 2,0    (10)",
    "11": "RMSE = sqrt((1 / (N · T)) · Σ_(n,t)(y_n,t - y_hat,n,t)^2) × 100%    (11)",
    "12": "PVR_dis = (Σ_t 1(I_t < -τ) · 1(Δy_hat,t > 0)) / (Σ_t 1(I_t < -τ))    (12)"

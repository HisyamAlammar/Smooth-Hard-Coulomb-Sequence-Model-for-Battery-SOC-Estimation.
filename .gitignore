# ==========================================================
# Heavy datasets and generated arrays
# Keep raw/processed data local. The README explains expected layout.
# ==========================================================
data/raw/**
!data/raw/.gitkeep
data/processed/**
!data/processed/.gitkeep
data/**/*.csv
data/**/*.mat
data/**/*.npy
data/**/*.npz
data/**/*.zip
data/**/*.h5
data/**/*.hdf5
data/**/*.mlx
data/**/*.m
data/**/*.pptx
data/**/*.pdf


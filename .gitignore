# ==========================================================
*.pt
*.pth
*.ckpt
models/
checkpoints/

# ==========================================================
# Logs
# Historical JSON/CSV logs are small and useful for ablation notebooks.
# Other log dump formats stay ignored.
# ==========================================================
*.log
logs/*
!logs/.gitkeep
!logs/*.json
!logs/*.csv

# ==========================================================
# Outputs
# Keep only lightweight reviewer evidence: JSON ledgers and selected figures.
# Heavy checkpoints/arrays/raw CSV exports remain ignored.
# ==========================================================
outputs/*
!outputs/.gitkeep
!outputs/data_audit_tables.json
!outputs/data_audit_tables.md

!outputs/v5_contextual/
outputs/v5_contextual/*
!outputs/v5_contextual/sprint50_contextual/
